---
import "@/styles/globals.css";
import { Button } from "@/components/ui/button";

const {
  title = "Pronto Coffee Co.",
  description = "Coffee, breakfast bites, and a welcoming neighborhood cafe experience.",
  includeFormScript = false,
} = Astro.props;

const appUrl = import.meta.env.PUBLIC_APP_URL || "http://localhost:5173";
const currentPath = Astro.url.pathname;
const navItems = [
  { href: "/blog/", label: "Blog" },
  { href: "/menu/", label: "Menu" },
  { href: "/contact/", label: "Contact" },
];
const orderAheadHref = "/order-ahead/";

const isActive = (href) => currentPath === href || (href !== "/" && currentPath.startsWith(href));
---

<!doctype html>
<html lang="en" class="scroll-smooth" data-app-url={appUrl}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href="/assets/images/coffee-favicon.ico" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-background text-foreground">
    <div class="relative overflow-hidden">
      <header class="fixed top-0 z-40 w-full border-b border-border bg-white/95 backdrop-blur-sm">
        <div class="mx-auto flex h-16 max-w-7xl items-center justify-between gap-4 px-4 md:px-6">
          <a href="/" class="text-lg font-bold tracking-tight text-foreground">
            Pronto Coffee Co.
          </a>
          <nav class="hidden items-center gap-7 text-sm font-medium md:flex">
            {navItems.map((item) => (
              <a
                href={item.href}
                class:list={[
                  "pb-1 transition-colors hover:text-foreground",
                  isActive(item.href)
                    ? "border-b-2 border-foreground text-foreground"
                    : "text-muted-foreground",
                ]}
              >
                {item.label}
              </a>
            ))}
          </nav>
          <div class="flex items-center gap-3">
            <Button as="a" href={orderAheadHref} size="sm" className="hidden sm:inline-flex">
              Order Ahead
            </Button>
            <div class="hidden lg:block">
              <Button as="a" href="/login" data-app-path="/login" size="sm" variant="outline">
                Staff Portal
              </Button>
            </div>
            <details class="md:hidden">
              <summary class="list-none">
                <span class="inline-flex h-9 cursor-pointer items-center justify-center rounded-lg border border-border bg-card px-4 text-sm font-semibold text-foreground shadow-sm">
                  Menu
                </span>
              </summary>
              <div class="absolute right-4 top-16 w-60 rounded-lg border border-border bg-card p-4 shadow-xl">
                <div class="flex flex-col gap-3 text-sm">
                  {navItems.map((item) => (
                    <a href={item.href} class="transition-colors text-muted-foreground hover:text-foreground">
                      {item.label}
                    </a>
                  ))}
                  <a href={orderAheadHref} class="transition-colors text-muted-foreground hover:text-foreground">Order Ahead</a>
                  <a href="/login" data-app-path="/login" class="transition-colors text-muted-foreground hover:text-foreground">Staff Portal</a>
                </div>
              </div>
            </details>
          </div>
        </div>
      </header>

      <main class="pt-16">
        <slot />
      </main>

      <footer class="border-t border-border bg-slate-50">
        <div class="mx-auto grid max-w-7xl gap-8 px-4 py-12 text-sm md:grid-cols-2 md:px-6 lg:grid-cols-4">
          <div class="space-y-4">
            <p class="font-semibold text-foreground">Pronto Coffee Co.</p>
            <p class="max-w-xs text-xs leading-6 text-muted-foreground">
              Precision-roasted coffee, cafe favorites, and fast pickup from Costa Mesa.
            </p>
            <p class="text-xs text-muted-foreground">© 2026 Pronto Coffee Co.</p>
          </div>
          <div class="space-y-3">
            <p class="font-semibold text-foreground">Explore</p>
            <a href="/blog/" class="block text-muted-foreground hover:text-foreground">Blog</a>
            <a href="/menu/" class="block text-muted-foreground hover:text-foreground">Menu</a>
            <a href="/contact/" class="block text-muted-foreground hover:text-foreground">Contact</a>
          </div>
          <div class="space-y-3">
            <p class="font-semibold text-foreground">Pickup</p>
            <a href={orderAheadHref} class="block text-muted-foreground hover:text-foreground">Order Ahead</a>
          </div>
          <div class="space-y-3">
            <p class="font-semibold text-foreground">Team</p>
            <a href="/login" data-app-path="/login" class="block text-muted-foreground hover:text-foreground">Staff Portal</a>
            <a href="/contact/" class="block text-muted-foreground hover:text-foreground">Wholesale</a>
          </div>
        </div>
      </footer>
    </div>

    {includeFormScript ? <script is:inline src="/assets/js/form.js"></script> : null}
    <script is:inline src="/assets/js/app-links.js"></script>
  </body>
</html>
