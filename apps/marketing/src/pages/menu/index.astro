---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeader from "@/components/marketing/SectionHeader.astro";
import { MenuProductCard } from "@/components/marketing/MarketingCards";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import {
  defaultLocation,
  menuCategories,
  seasonalHighlights,
} from "@pronto/menu";

const orderAheadHref = "/order-ahead/";
const menuItemsByName = new Map(
  menuCategories.flatMap((category) =>
    category.items.map((item) => [
      item.name,
      {
        ...item,
        category: category.staffLabel,
      },
    ]),
  ),
);
const seasonalHighlightCards = seasonalHighlights
  .map((itemName) => menuItemsByName.get(itemName))
  .filter(Boolean);
---

<BaseLayout title="Menu - Pronto Coffee Co." description="Explore Pronto Coffee Co. drinks and cafe bites.">
  <section class="mx-auto max-w-7xl px-4 pb-8 pt-16 md:px-6 lg:pt-20">
    <SectionHeader
      align="center"
      headingLevel="h1"
      eyebrow={defaultLocation.serviceModel}
      title="Our curated menu"
      description="Signature espresso, cold brew, tea, breakfast, and pastries. Every menu surface pulls from the same shared data used by staff order entry and customer pickup."
    />

  </section>

  <nav class="sticky top-16 z-30 bg-background/65 px-4 py-3 backdrop-blur md:px-6" aria-label="Menu categories">
    <div class="mx-auto max-w-fit">
      <div class="flex max-w-full flex-wrap justify-center gap-1 rounded-lg border border-border bg-secondary/75 background-blur p-1 shadow-sm">
        {menuCategories.map((category) => (
          <a
            href={`#${category.id}`}
            data-menu-nav={category.id}
            aria-current={category.id === menuCategories[0].id ? "true" : "false"}
            class:list={[
              "whitespace-nowrap rounded-md px-4 py-2 text-sm font-semibold transition-colors",
              category.id === menuCategories[0].id
                ? "bg-primary text-primary-foreground shadow-sm"
                : "text-muted-foreground hover:bg-white hover:text-foreground",
            ]}
          >
            {category.staffLabel}
          </a>
        ))}
      </div>
    </div>
  </nav>

  <section class="mx-auto max-w-7xl px-4 py-12 md:px-6" data-menu-region>
    <div class="grid gap-12">
      {menuCategories.map((category) => (
        <div id={category.id} class="scroll-mt-48" data-menu-category={category.id}>
          <div class="mb-6 flex flex-col justify-between gap-3 md:flex-row md:items-end">
            <div>
              <Badge>{category.staffLabel}</Badge>
              <h2 class="mt-3 text-3xl font-semibold text-foreground">{category.title}</h2>
              <p class="mt-2 max-w-2xl text-sm leading-7 text-muted-foreground">{category.description}</p>
            </div>
            <Button as="a" href={orderAheadHref} variant="outline" className="w-fit">Order Ahead</Button>
          </div>
          <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3" data-menu-skeleton aria-hidden="true">
            {Array.from({ length: Math.min(category.items.length, 3) }).map(() => (
              <article class="overflow-hidden rounded-lg border border-border bg-white shadow-sm">
                <div class="h-56 animate-pulse bg-secondary"></div>
                <div class="space-y-4 p-5">
                  <div class="flex items-start justify-between gap-4">
                    <div class="h-6 w-2/3 animate-pulse rounded-md bg-secondary"></div>
                    <div class="h-8 w-14 animate-pulse rounded-md bg-secondary"></div>
                  </div>
                  <div class="space-y-2">
                    <div class="h-4 animate-pulse rounded-md bg-secondary"></div>
                    <div class="h-4 w-5/6 animate-pulse rounded-md bg-secondary"></div>
                  </div>
                  <div class="flex gap-2">
                    <div class="h-7 w-20 animate-pulse rounded-full bg-secondary"></div>
                    <div class="h-7 w-24 animate-pulse rounded-full bg-secondary"></div>
                  </div>
                  <div class="h-10 animate-pulse rounded-md bg-secondary"></div>
                </div>
              </article>
            ))}
          </div>
          <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3" data-menu-items>
            {category.items.map((item) => (
              <MenuProductCard item={{ ...item, category: category.staffLabel }} client:load />
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <style>
    [data-menu-region] [data-menu-items] {
      display: none;
    }

    [data-menu-region].is-loaded [data-menu-skeleton] {
      display: none;
    }

    [data-menu-region].is-loaded [data-menu-items] {
      display: grid;
    }
  </style>

  <noscript>
    <style>
      [data-menu-region] [data-menu-skeleton] {
        display: none;
      }

      [data-menu-region] [data-menu-items] {
        display: grid;
      }
    </style>
  </noscript>

  <script>
    const menuRegion = document.querySelector("[data-menu-region]");
    const navLinks = Array.from(document.querySelectorAll("[data-menu-nav]"));
    const categories = Array.from(document.querySelectorAll("[data-menu-category]"));
    const activeClasses = ["bg-primary", "text-primary-foreground", "shadow-sm"];
    const inactiveClasses = ["text-muted-foreground", "hover:bg-white", "hover:text-foreground"];
    const initialCategoryId = window.location.hash.replace("#", "");
    let clickedCategoryLockUntil = 0;
    let scrollFrame = null;

    function setActiveCategory(categoryId) {
      navLinks.forEach((link) => {
        const isActive = link.getAttribute("data-menu-nav") === categoryId;

        link.classList.toggle(activeClasses[0], isActive);
        link.classList.toggle(activeClasses[1], isActive);
        link.classList.toggle(activeClasses[2], isActive);
        inactiveClasses.forEach((className) => link.classList.toggle(className, !isActive));
        link.setAttribute("aria-current", isActive ? "true" : "false");
      });
    }

    navLinks.forEach((link) => {
      link.addEventListener("click", (event) => {
        const categoryId = link.getAttribute("data-menu-nav");
        const category = categoryId ? document.getElementById(categoryId) : null;

        if (!categoryId || !category) {
          return;
        }

        event.preventDefault();
        clickedCategoryLockUntil = Date.now() + 700;
        setActiveCategory(categoryId);
        history.replaceState(null, "", `#${categoryId}`);
        category.scrollIntoView({ block: "start" });
      });
    });

    if (initialCategoryId && categories.some((category) => category.id === initialCategoryId)) {
      setActiveCategory(initialCategoryId);
    }

    function updateActiveCategoryFromScroll() {
      if (Date.now() < clickedCategoryLockUntil || categories.length === 0) {
        return;
      }

      const stickyOffset = 170;
      const activeCategory = categories.reduce((currentCategory, category) => {
        const categoryTop = category.getBoundingClientRect().top;

        if (categoryTop <= stickyOffset) {
          return category;
        }

        return currentCategory;
      }, categories[0]);

      setActiveCategory(activeCategory.id);
    }

    function queueActiveCategoryUpdate() {
      if (scrollFrame) {
        return;
      }

      scrollFrame = window.requestAnimationFrame(() => {
        scrollFrame = null;
        updateActiveCategoryFromScroll();
      });
    }

    window.addEventListener("scroll", queueActiveCategoryUpdate, { passive: true });
    window.addEventListener("resize", queueActiveCategoryUpdate);
    queueActiveCategoryUpdate();

    window.setTimeout(() => {
      menuRegion?.classList.add("is-loaded");
      queueActiveCategoryUpdate();
    }, 450);
  </script>

  <section class="bg-primary px-4 py-16 text-primary-foreground md:px-6">
    <div class="mx-auto max-w-7xl space-y-8">
      <div class="max-w-2xl">
        <Badge className="bg-white/10 text-white">Seasonal highlights</Badge>
        <h2 class="mt-4 text-4xl font-semibold text-white">Try this season's must-have drinks and pastries</h2>
        <p class="mt-4 max-w-2xl text-sm leading-7 text-white/75">
          Small-batch drinks and bakery features that our customers currently love.
        </p>
      </div>
      <div class="grid gap-5 md:grid-cols-3">
        {seasonalHighlightCards.map((item) => (
          <article class="overflow-hidden rounded-lg border border-white/15 bg-white text-foreground shadow-sm">
            <div class="h-56 overflow-hidden bg-secondary">
              <img
                src={item.image}
                alt={item.name}
                class="h-full w-full object-cover transition-transform duration-500 hover:scale-[1.03]"
                loading="lazy"
              />
            </div>
            <div class="space-y-3 p-5">
              <div class="flex items-center justify-between gap-3">
                <Badge>{item.category}</Badge>
                <span class="rounded-md bg-secondary px-2 py-1 text-sm font-semibold text-secondary-foreground">{item.price}</span>
              </div>
              <h3 class="text-2xl font-semibold text-foreground">{item.name}</h3>
              <p class="text-sm leading-7 text-muted-foreground">{item.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
