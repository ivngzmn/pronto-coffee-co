---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { CustomerAuthExperience } from "@/components/CustomerAuthExperience";

const apiUrl = import.meta.env.PUBLIC_API_URL || "http://localhost:3000";
---

<BaseLayout title="Customer Sign In - Pronto Coffee Co." description="Sign in or create a customer account to place Pronto pickup orders.">
  <CustomerAuthExperience client:load apiUrl={apiUrl} />
</BaseLayout>
