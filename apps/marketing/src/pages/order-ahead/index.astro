---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { OrderAheadExperience } from "@/components/OrderAheadExperience";

const apiUrl = import.meta.env.PUBLIC_API_URL || "http://localhost:3000";
---

<BaseLayout title="Order Ahead - Pronto Coffee Co." description="Order ahead pickup for coffee, breakfast, and cafe favorites.">
  <section class="max-w-5xl px-4 pb-20 mx-auto pt-14 md:px-6 lg:pt-20">
    <OrderAheadExperience client:load apiUrl={apiUrl} />
  </section>
</BaseLayout>
