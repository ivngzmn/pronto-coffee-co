---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";

const pillars = [
  {
    title: "House Coffee",
    description: "Espresso drinks, smooth lattes, and bold cold brew built for the everyday morning stop.",
    image: "/assets/images/coffee-cup.png",
  },
  {
    title: "Breakfast Favorites",
    description: "Breakfast sandwiches, avocado toast, pastries, and cafe bites that belong next to a fresh cup.",
    image: "/assets/images/tea-cup.png",
  },
  {
    title: "Cafe Routine",
    description: "A warm counter, easy pickup, and a neighborhood coffee stop built for daily repeat visits.",
    image: "/assets/images/restaurant.png",
  },
];

const highlights = [
  "Signature lattes and cold brew",
  "Breakfast bites and toast",
  "Cafe + quick pickup energy",
];
---

<BaseLayout title="Pronto Coffee Co." description="Coffee, breakfast bites, and a welcoming neighborhood cafe.">
  <section class="mx-auto grid max-w-6xl items-center gap-10 px-4 pb-16 pt-14 md:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:pb-24 lg:pt-20">
    <div class="space-y-6">
      <Badge>Cafe + Pickup</Badge>
      <h1 class="max-w-3xl text-5xl font-semibold leading-tight text-foreground md:text-6xl">
        Coffee, breakfast, and an easy stop on the way into the day.
      </h1>
      <p class="max-w-2xl text-base leading-8 text-muted-foreground md:text-lg">
        Pronto Coffee Co. is built around the things people come back for: smooth espresso drinks, bold cold brew, breakfast sandwiches, fresh pastries, and a cafe that feels good whether you stay a while or order ahead.
      </p>
      <div class="flex flex-wrap gap-3">
        <Button as="a" href="/menu/" size="lg">View Food & Drinks</Button>
        <Button as="a" href="/order-ahead/" variant="outline" size="lg">
          Order Ahead
        </Button>
      </div>
      <div class="grid gap-3 pt-4 sm:grid-cols-3">
        {highlights.map((highlight) => (
          <Card className="rounded-3xl border-border/70 bg-card/70">
            <CardContent className="p-4 text-sm font-medium text-foreground">{highlight}</CardContent>
          </Card>
        ))}
      </div>
    </div>
    <Card className="overflow-hidden border-border/70 text-stone-50">
      <CardContent className="p-0">
        <img
          src="/assets/images/coffee_hero.png"
          alt="Illustrated coffee and cafe food arrangement."
          class="h-full w-full bg-[radial-gradient(circle_at_top,_rgba(245,158,11,0.18),_transparent_55%)] object-cover p-6"
        />
      </CardContent>
    </Card>
  </section>

  <section class="max-w-6xl px-4 py-12 mx-auto md:px-6 lg:py-16">
    <div class="grid gap-6 md:grid-cols-3">
      {pillars.map((pillar) => (
        <Card className="rounded-[32px]">
          <CardHeader>
            <img src={pillar.image} alt="" class="h-14 w-14" />
            <CardTitle>{pillar.title}</CardTitle>
            <CardDescription>{pillar.description}</CardDescription>
          </CardHeader>
        </Card>
      ))}
    </div>
  </section>

  <section class="mx-auto grid max-w-6xl gap-6 px-4 py-12 md:px-6 lg:grid-cols-[0.95fr_1.05fr] lg:py-16">
    <Card className="overflow-hidden">
      <CardContent className="p-0">
        <img src="/assets/images/coffee_growth.png" alt="Illustrated person holding a growing plant." class="object-cover w-full h-full" />
      </CardContent>
    </Card>
      <Card>
        <CardHeader>
          <Badge className="w-fit">Location feel</Badge>
          <CardTitle className="text-3xl">From the first pour to the last breakfast bite, keep it simple and craveable</CardTitle>
          <CardDescription className="text-base leading-7">
          The best coffee-shop sites lead with what guests want to know right away: what is pouring, what is coming out of the kitchen, where the cafe is, and how quickly they can grab their order.
          </CardDescription>
        </CardHeader>
      <CardContent className="space-y-4 text-sm leading-7 text-muted-foreground">
        <!--  TODO:put some relative copy here -->
        <div class="pt-2">
          <Button as="a" href="/contact/" variant="secondary">Find the cafe</Button>
        </div>
      </CardContent>
    </Card>
  </section>
</BaseLayout>
