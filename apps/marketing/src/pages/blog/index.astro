---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeader from "@/components/marketing/SectionHeader.astro";
import NewsletterCta from "@/components/marketing/NewsletterCta.astro";
import { BlogCard } from "@/components/marketing/MarketingCards";

const featuredPost = {
  title: "The evolution of the perfect roast",
  href: "/blog/how-to-brew-the-perfect-cup/",
  excerpt:
    "A practical look at how water, grind, roast profile, and service timing all shape the final cup.",
  image: "/assets/images/stitch/stitch-06.webp",
  imageAlt: "Barista pouring latte art in a modern cafe.",
  category: "Roastery News",
  date: "May 15, 2026",
};

const posts = [
  {
    title: "How to brew the perfect cup",
    href: "/blog/how-to-brew-the-perfect-cup/",
    excerpt: "A grounded guide to dialing in water, grind, timing, and repeatable morning coffee.",
    image: "/assets/images/growth_tips_hero.jpg",
    category: "Brewing Tips",
    date: "April 12, 2026",
  },
  {
    title: "Designing the faster pickup bar",
    excerpt: "How order-ahead tickets move from customer login to the same live queue staff already trust.",
    image: "/assets/images/stitch/stitch-08.webp",
    category: "Cafe Workflow",
    date: "March 28, 2026",
  },
  {
    title: "Origin notes without the noise",
    excerpt: "A plain-language way to choose beans by sweetness, body, acidity, and everyday brew method.",
    image: "/assets/images/stitch/stitch-09.webp",
    category: "Origins",
    date: "March 9, 2026",
  },
  {
    title: "What makes a breakfast pairing work",
    excerpt: "Balancing espresso, cold brew, pastry, and savory favorites for the morning rush.",
    image: "/assets/images/menu/pronto-breakfast-sandwich.webp",
    category: "Menu",
    date: "February 24, 2026",
  },
];
---

<BaseLayout title="Blog - Pronto Coffee Co." description="Pronto Coffee Co. journal and shop notes.">
  <section class="mx-auto max-w-7xl px-4 py-16 md:px-6 lg:py-20">
    <SectionHeader
      eyebrow="Journal"
      headingLevel="h1"
      title="Roasting notes, brewing guides, and cafe workflow."
      description="A customer-facing journal for the practical details behind the Pronto menu and the systems that keep pickup moving."
    />
    <div class="mt-10">
      <BlogCard post={featuredPost} featured />
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-20 md:px-6">
    <div class="mb-8 flex flex-wrap gap-2">
      {["All", "Brewing Tips", "Origins", "Cafe Workflow"].map((label) => (
        <button class="rounded-lg border border-border bg-white px-4 py-2 text-sm font-semibold text-muted-foreground transition-colors hover:text-foreground">
          {label}
        </button>
      ))}
    </div>
    <div class="grid gap-5 md:grid-cols-2">
      {posts.map((post) => (
        <BlogCard post={post} />
      ))}
    </div>
  </section>

  <NewsletterCta tone="light" title="Notes worth opening." description="Get brew guides, seasonal drops, and cafe updates without noise." />
</BaseLayout>
