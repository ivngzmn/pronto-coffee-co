{
  "version": "1.0.0",
  "name": "node-server",
  "main": "server.js",
  "license": "MIT",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "start": "node server.js",
    "dev:app": "node --watch server.js",
    "dev:marketing": "serve marketing-site -l 4321",
    "dev": "concurrently \"npm:dev:app\" \"npm:dev:marketing\"",
    "build:css": "tailwindcss -i ./public/css/tailwind.css -o ./public/css/index.css",
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev:css": "tailwindcss -i ./public/css/tailwind.css -o ./public/css/index.css --watch"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "connect-flash": "~0.1.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "mongodb": "^7.1.1",
    "mongoose": "^9.4.1",
    "morgan": "^1.10.1",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "concurrently": "^9.2.1",
    "serve": "^14.2.6",
    "tailwindcss": "^4.2.2"
  }
}
